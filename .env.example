# --- Telegram (получить на https://my.telegram.org/apps) ---
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here
# Кому разрешено кидать файлы (твой Telegram user ID, через запятую)
TG_ALLOWED_USERS=123456789

# --- Max через GREEN-API (получить на https://console.green-api.com) ---
GA_INSTANCE_ID=1100000001
GA_API_TOKEN=your_green_api_token_here
# apiUrl из консоли GREEN-API (одинаковый для обоих полей)
GA_API_URL=https://3100.api.green-api.com
GA_MEDIA_URL=https://3100.api.green-api.com
# Куда отправлять файл в Max (твой номер, начиная с 7)
MAX_TARGET_PHONE=79999999999

# --- Папка для загрузок (Max видит только её) ---
UPLOAD_DIR=uploads
